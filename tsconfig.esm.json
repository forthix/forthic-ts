{
  "compilerOptions": {
    "outDir": "./dist/esm",
    "module": "ESNext",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/__tests__",
    "src/**/__mocks__",
    "src/**/tests",
    "src/grpc/client.ts",
    "src/grpc/server.ts",
    "src/grpc/index.ts",
    "src/grpc/browser-stub.ts",
    "src/grpc/remote_runtime_module.ts"
  ]
}